---
import "../styles/global.css";
import CookieBanner from "../components/CookieBanner.astro";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = "Asistente gratuito con IA para elegir tu próximo portátil, móvil, tablet o accesorio según tu uso y presupuesto. Buscamos entre los mejores proveedores en menos de 2 minutos.",
  canonical = "https://easychoose.es/",
} = Astro.props;

const ogImage = "https://easychoose.es/og-image.png";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <!-- Google Tag Manager -->
    <script is:inline>
      // Consent Mode: denied by default until user accepts
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        'analytics_storage': 'denied',
        'ad_storage': 'denied',
        'ad_user_data': 'denied',
        'ad_personalization': 'denied'
      });
      // Restore consent if previously accepted
      if (typeof localStorage !== 'undefined' && localStorage.getItem('cookie_consent') === 'accepted') {
        gtag('consent', 'update', {
          'analytics_storage': 'granted',
          'ad_storage': 'granted',
          'ad_user_data': 'granted',
          'ad_personalization': 'granted'
        });
      }
    </script>
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-WKHGW4FH');</script>
    <!-- End Google Tag Manager -->
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="EasyChoose" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#6C63FF" />
    <meta name="application-name" content="EasyChoose" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="EasyChoose — Asistente de compra de tecnología con IA" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="EasyChoose" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="es" href="https://easychoose.es/" />
    <link rel="alternate" hreflang="x-default" href="https://easychoose.es/" />
    
    <!-- Structured Data: Organization -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "EasyChoose",
      "url": "https://easychoose.es",
      "logo": "https://easychoose.es/choose-removebg-preview.png"
    }
    </script>

    <!-- Structured Data: WebApplication -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "EasyChoose",
      "alternateName": "EasyChoose — Asistente de Compra de Tecnología",
      "description": "Asistente gratuito con IA para elegir portátiles, móviles, tablets y accesorios según tu uso y presupuesto. Buscamos entre los mejores proveedores del mercado.",
      "url": "https://app.easychoose.es",
      "applicationCategory": "ShoppingApplication",
      "operatingSystem": "Web",
      "inLanguage": "es",
      "isAccessibleForFree": true,
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "EUR"
      },
      "publisher": {
        "@type": "Organization",
        "name": "EasyChoose",
        "url": "https://easychoose.es"
      }
    }
    </script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WKHGW4FH"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <CookieBanner />
    <header class="header">
      <nav class="container">
        <div class="logo">
          <img
            src="/choose-removebg-preview.png"
            alt="choose logo"
            class="logo-img"
          />
        </div>
        <ul class="nav-links">
          <li><a href="#categories">Categorías</a></li>
          <li><a href="#how-it-works">Cómo funciona</a></li>
          <li><a href="#social-proof">Testimonios</a></li>
          <li><a href="#faq">FAQ</a></li>
        </ul>
        <a href="https://app.easychoose.es" class="btn btn-primary">Empieza el Asistente</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer-content">
          <div class="footer-info">
            <img
              src="/choose-removebg-preview.png"
              alt="choose logo"
              class="logo-img footer-logo"
            />
            <p>Simplificamos la compra de tecnología con IA. Gratis y sin registro.</p>
          </div>
          <div class="footer-links">
            <h4>Enlaces</h4>
            <ul>
              <li><a href="#categories">Categorías</a></li>
              <li><a href="#how-it-works">Cómo funciona</a></li>
              <li><a href="#social-proof">Testimonios</a></li>
              <li><a href="#faq">FAQ</a></li>
            </ul>
          </div>
          <div class="footer-links">
            <h4>Legal</h4>
            <ul>
              <li><a href="/politica-de-privacidad">Privacidad</a></li>
              <li><a href="/aviso-legal">Aviso Legal</a></li>
              <li><a href="/politica-de-cookies">Cookies</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>
            &copy; {new Date().getFullYear()} EasyChoose. Todos los derechos reservados.
          </p>
          <p class="credits">
            Made with <span class="heart">💙</span> by <a
              href="http://www.rpidev.com"
              target="_blank">rpidev</a
            >
          </p>
        </div>
      </div>
    </footer>

    <style>
      .header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        background-color: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(10px);
        z-index: 1000;
        padding: 1rem 0;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo-img {
        height: 40px;
        width: auto;
      }

      .footer-logo {
        filter: brightness(0) invert(1);
        height: 50px;
      }

      .nav-links {
        display: flex;
        gap: 2rem;
      }

      .nav-links li a {
        font-weight: 500;
        color: var(--color-text-muted);
      }

      .nav-links li a:hover {
        color: var(--color-primary);
      }

      .footer {
        background-color: var(--color-dark);
        color: white;
        padding: 4rem 0 2rem;
        margin-top: 4rem;
      }

      .footer-content {
        display: flex;
        justify-content: space-between;
        margin-bottom: 3rem;
      }

      .footer-info p {
        margin-top: 1rem;
        color: #aaa;
      }

      .footer-links h4 {
        margin-bottom: 1.5rem;
      }

      .footer-links ul li {
        margin-bottom: 0.5rem;
      }

      .footer-links ul li a {
        color: #aaa;
      }

      .footer-links ul li a:hover {
        color: var(--color-secondary);
      }

      .footer-bottom {
        text-align: center;
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        color: #666;
        font-size: 0.9rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .credits a {
        color: var(--color-secondary);
        font-weight: 600;
      }

      .credits a:hover {
        text-decoration: underline;
      }

      .heart {
        color: #3b82f6;
      }

      @media (max-width: 768px) {
        .nav-links {
          display: none;
        }

        .footer-content {
          flex-direction: column;
          gap: 2rem;
        }
      }
    </style>
  </body>
</html>
