const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Cómo elegir tecnología con EasyChoose",
  description:
    "Proceso guiado para elegir portátil, móvil, tablet, ordenador, accesorio o movilidad eléctrica con ayuda de IA.",
  totalTime: "PT2M",
  estimatedCost: {
    "@type": "MonetaryAmount",
    currency: "EUR",
    value: "0",
  },
  step: steps.map((step, index) => ({
    "@type": "HowToStep",
    position: index + 1,
    name: step.title,
    text: step.description,
  })),
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Categorías que cubre EasyChoose",
  itemListElement: categories.map((category, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: category.title,
    description: category.description,
    url: appUrl,
  })),
};

const catalogSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Segmentos del catálogo de EasyChoose",
  itemListElement: catalogSources.map((source, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: source.title,
    description: source.description,
    url: appUrl,
  })),
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Asistente IA para elegir tecnología",
  serviceType: "Recomendación personalizada de productos tecnológicos",
  url: canonical,
  provider: {
    "@type": "Organization",
    name: "EasyChoose",
    url: canonical,
  },
  areaServed: {
    "@type": "Country",
    name: "España",
  },
  audience: {
    "@type": "Audience",
    audienceType: "Consumidores que quieren elegir tecnología con seguridad",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "EUR",
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: canonical },
  ],
};

const pageSchemas = [faqSchema, howToSchema, itemListSchema, catalogSchema, serviceSchema, breadcrumbSchema];
---

<Layout
  title="Qué portátil, móvil o tablet comprar | EasyChoose"
  description="Asistente gratuito con IA para elegir portátil, móvil o tablet según tu uso real y presupuesto. Recomendación en 2 minutos, sin registro."
  canonical={canonical}
  keywords={keywords}
  preloadImage={optimizedHero.src}
>
  {pageSchemas.map((schema) => (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
  ))}

  <Section className="hero-section" variant="glass">
    <div class="hero-grid">
      <div class="hero-copy animate-fade-in">
        <div class="hero-meta">
          <span class="badge">Asistente IA gratuito</span>
          <span class="last-updated">Catálogo revisado mensualmente · Última revisión: {new Date().toLocaleDateString("es-ES", { month: "long", year: "numeric" })}</span>
        </div>
        <h1>
          Qué portátil, móvil o tablet comprar <span class="highlight">sin perder horas comparando</span>
        </h1>
        <p class="hero-answer-direct">
          Elegir portátil, móvil o tablet depende de tu uso real y tu presupuesto, no de la marca más anunciada. EasyChoose te da una recomendación concreta en menos de 2 minutos: responde 4 preguntas y el asistente IA filtra el mercado por ti.
        </p>
        <p class="hero-answer">
          EasyChoose es un asistente gratuito con IA que traduce tus necesidades en tecnología adecuada, sin obligarte a interpretar fichas técnicas ni comparar decenas de modelos similares.
        </p>
        <div class="hero-actions">
          <a href={appUrl} class="btn btn-primary btn-large">Empieza el Asistente Gratis</a>
          <a href="#how-it-works" class="btn-text">Ver cómo funciona</a>
        </div>
        <ul class="hero-pills" aria-label="Beneficios clave">
          <li>Gratis y sin registro</li>
          <li>Lenguaje claro para no expertos</li>
          <li>Comparación útil para decidir mejor</li>
        </ul>
      </div>

      <div class="hero-visual">
        <div class="hero-illustration-wrap" aria-label="Ilustración del asistente EasyChoose">
          <div class="hero-floating hero-floating-top hero-floating-outside">
            <span class="emoji-inline" aria-hidden="true"><Icon name="chat-bubble" /></span>
            <span>Te guiamos paso a paso</span>
          </div>
          <Image
            src={heroImg}
            alt="Ilustración del asistente EasyChoose recomendando tecnología según uso y presupuesto"
            class="hero-image"
            width={1000}
            height={1000}
            format="webp"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </Section>

  <Section id="features" className="features-section" variant="light">
    <div class="section-header">
      <span class="badge">Nuestra tecnología</span>
      <h2>Diseñado para la eficiencia</h2>
      <p>EasyChoose combina un catálogo actualizado con un motor de recomendación basado en uso real y un chat de IA integrado para resolver dudas antes de comprar. Los tres componentes reducen el tiempo de decisión de horas a minutos.</p>
    </div>
    <div class="feature-grid">
      {features.map((feature) => (
        <article class={`feature-card ${feature.highlight ? "feature-card-highlight" : ""}`}>
          <div class="icon-badge icon-badge-lg" aria-hidden="true"><Icon name={feature.icon} /></div>
          <h3>{feature.title}</h3>
          <p>{feature.text}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section id="answer-first" variant="light">
    <div class="section-header">
      <span class="badge">Respuesta rápida</span>
      <h2>¿Qué hace EasyChoose y para quién sirve?</h2>
      <p class="answer-first">
        EasyChoose sirve para personas que quieren comprar tecnología sin quedarse atrapadas entre especificaciones, comparativas interminables y miedo a equivocarse. Es útil tanto si no sabes de hardware como si sí sabes pero quieres llegar antes a una buena decisión.
      </p>
    </div>
    <div class="use-cases-grid">
      {useCases.map((useCase) => (
        <article class="info-card friendly-card friendly-centered">
          <div class="icon-badge" aria-hidden="true"><Icon name={useCase.icon} /></div>
          <h3>{useCase.title}</h3>
          <p>{useCase.description}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section id="problem" variant="glass">
    <div class="section-header">
      <span class="badge">El problema</span>
      <h2>¿Por qué comprar tecnología abruma tanto?</h2>
      <p>
        Comprar tecnología en España es habitual, pero decidir bien sigue siendo difícil. Según la <a href="https://www.ine.es/dyngs/INEbase/es/operacion.htm?c=Estadistica_C&cid=1254736176741&menu=resultados&idp=1254735976608" target="_blank" rel="noopener noreferrer">Encuesta TIC-Hogares 2023 del INE</a>, el 97,4% de los españoles de 16 a 74 años usa internet, y los dispositivos tecnológicos encabezan el gasto en comercio electrónico. Sin embargo, según el <a href="https://www.ontsi.es/es" target="_blank" rel="noopener noreferrer">informe eSPAIN 2024 del Observatorio Nacional de Tecnología y Sociedad (ONTSI)</a>, la sobrecarga de opciones es uno de los principales frenos en la compra de electrónica: demasiados modelos, demasiadas fichas técnicas y pocas respuestas claras. EasyChoose parte de la pregunta correcta: qué necesitas tú, en qué contexto y cuánto quieres gastar.
      </p>
    </div>
    <div class="problem-grid">
      {problems.map((problem) => (
        <article class="problem-item plain-problem">
          <div class="icon-badge" aria-hidden="true"><Icon name={problem.icon} /></div>
          <h3>{problem.title}</h3>
          <p>{problem.description}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section id="how-it-works" variant="light">
    <div class="section-header">
      <span class="badge">Proceso</span>
      <h2>¿Cómo funciona el asistente para elegir tecnología?</h2>
      <p>
        El asistente funciona en cuatro pasos: eliges la categoría de producto, indicas tu uso real, ajustas presupuesto y preferencias, y recibes hasta 9 recomendaciones con un chat de IA para resolver la última duda antes de decidir. Todo el proceso dura menos de 2 minutos y no requiere registro.
      </p>
    </div>
    <div class="steps-grid">
      {steps.map((step, index) => (
        <article class="step-card">
          <div class="step-number">{index + 1}</div>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section id="categories" variant="glass">
    <div class="section-header">
      <span class="badge">Categorías</span>
      <h2>¿Qué tipo de producto puedes elegir con EasyChoose?</h2>
      <p>
        EasyChoose cubre seis categorías de compra tecnológica: portátiles, smartphones, tablets, ordenadores de sobremesa, accesorios y movilidad eléctrica. Cada categoría convierte la búsqueda en una conversación guiada por tu uso real y tu presupuesto, en lugar de un catálogo con cientos de modelos sin contexto.
      </p>
    </div>
    <div class="categories-grid">
      {categories.map((category) => (
        <article class="category-card">
          <div class="icon-badge icon-badge-lg" aria-hidden="true"><Icon name={category.icon} /></div>
          <h3>{category.title}</h3>
