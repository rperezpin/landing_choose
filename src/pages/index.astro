    guideLabel: "Guía completa del mejor portátil para teletrabajo →",
  },
  {
    icon: "desktop",
    question: "¿Qué PC de sobremesa comprar según mi presupuesto?",
    answer:
      "El equilibrio entre CPU, GPU y RAM debe ajustarse a tu uso real: gaming, oficina o creación de contenido priorizan componentes distintos. El asistente te orienta según tu caso.",
    guideUrl: "/mejor-pc-sobremesa/",
    guideLabel: "Guía completa del mejor PC de sobremesa →",
  },
];

const comparisonRows = [
  {
    factor: "Tiempo invertido",
    manual: "Horas comparando fichas técnicas, reviews y tiendas.",
    easychoose: "Un flujo guiado de pocos pasos con recomendación final clara.",
  },
  {
    factor: "Comprensión técnica",
    manual: "Tienes que interpretar specs y marketing de cada marca.",
    easychoose: "La IA traduce datos técnicos a impacto real en tu día a día.",
  },
  {
    factor: "Ajuste al presupuesto",
    manual: "Es fácil pagar de más por prestaciones que no vas a usar.",
    easychoose: "Prioriza valor, uso real y límites de precio desde el principio.",
  },
  {
    factor: "Dudas finales",
    manual: "La última incertidumbre suele obligarte a seguir buscando.",
    easychoose: "Puedes preguntar a la IA por batería, peso, cámara o compatibilidad antes de decidir.",
  },
  {
    factor: "Claridad de decisión",
    manual: "Muchísima información, poca conclusión accionable.",
    easychoose: "Una recomendación argumentada y fácil de entender.",
  },
];

const methodology = [
  {
    icon: "target",
    title: "Uso real antes que ficha técnica",
    description:
      "El asistente parte de lo que vas a hacer con el producto, no de una lista de especificaciones aisladas.",
  },
  {
    icon: "banknotes",
    title: "Valor por precio",
    description:
      "Compara opciones dentro de tu rango para evitar pagar de más o quedarte corto donde sí importa.",
  },
  {
    icon: "magnifying-glass",
    title: "Resultados que puedes interrogar",
    description:
      "Cada recomendación se puede revisar con el chat IA para convertir la duda final en una decisión informada.",
  },
  {
    icon: "cpu-chip",
    title: "Transparencia comercial",
    description:
      "EasyChoose puede recibir comisiones de afiliación, pero la recomendación se formula según adecuación al uso, no por patrocinio de marca.",
