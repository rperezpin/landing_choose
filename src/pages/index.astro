---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";

const appUrl = "https://app.easychoose.es/";
const canonical = "https://easychoose.es/";

const keywords = [
  "que portatil comprar",
  "que movil comprar",
  "que tablet comprar",
  "asistente IA para elegir tecnologia",
  "comparador de tecnologia",
  "recomendador de portatiles con IA",
  "recomendador de moviles con IA",
  "easychoose",
];

const steps = [
  {
    title: "Selecciona tu categoría",
    description:
      "Elige si buscas un portátil, móvil, tablet, ordenador, accesorio o un vehículo de movilidad eléctrica.",
  },
  {
    title: "Define tu uso real",
    description:
      "Indica si lo necesitas para estudiar, trabajar, jugar, crear contenido, desplazarte o resolver una necesidad concreta.",
  },
  {
    title: "Ajusta presupuesto y preferencias",
    description:
      "Filtra por sistema operativo, autonomía, pantalla, cámara, peso o cualquier extra importante para tu caso.",
  },
  {
    title: "Resuelve la última duda con IA",
    description:
      "Pregunta por batería, rendimiento, portabilidad o compatibilidad antes de decidir qué modelo te conviene más.",
  },
];

const useCases = [
  {
    icon: "🧠",
    title: "No sabes de tecnología",
    description:
      "EasyChoose traduce especificaciones complejas a recomendaciones claras para que compres con criterio aunque no seas experto.",
  },
  {
    icon: "🧭",
    title: "Sabes lo que quieres, pero no quieres perder tiempo",
    description:
      "Si ya conoces el mercado, el asistente te ahorra horas cribando modelos y te lleva directo a las opciones que encajan.",
  },
  {
    icon: "🎁",
    title: "Quieres acertar con un regalo o una compra importante",
    description:
      "La IA te ayuda a priorizar uso real, presupuesto y necesidades prácticas para reducir el riesgo de equivocarte.",
  },
];

const problems = [
  {
    icon: "😩",
    title: "Horas comparando lo mismo",
    description:
      "Decenas de modelos parecen equivalentes, pero cambian en lo que sí importa para tu uso diario.",
  },
  {
    icon: "⏳",
    title: "Especificaciones difíciles de interpretar",
    description:
      "RAM, núcleos, nits, refresco, autonomía o latencia no siempre se traducen en una decisión clara.",
  },
  {
    icon: "💸",
    title: "Miedo a pagar de más o a quedarte corto",
    description:
      "La compra tecnológica duele cuando inviertes sin saber si el producto encaja de verdad con tu caso.",
  },
];

const categories = [
  {
    icon: "💻",
    title: "Portátiles",
    description: "Laptops para trabajo, estudios, gaming, programación y creatividad.",
    priceRange: "€300 – €2.500",
    links: ["Mejor calidad-precio", "Para trabajo o estudios", "Gaming"],
  },
  {
    icon: "📱",
    title: "Smartphones",
    description: "Móviles Android y iPhone para batería, cámara, uso diario o gama alta.",
    priceRange: "€150 – €1.800",
    links: ["Menos de 500€", "Cámara profesional", "Android o iPhone"],
  },
  {
    icon: "📟",
    title: "Tablets",
    description: "Tablets e iPad para apuntes, lectura, dibujo, contenido multimedia y productividad ligera.",
    priceRange: "€200 – €1.200",
    links: ["Para estudiantes", "Dibujo y diseño", "iPad o Android"],
  },
  {
    icon: "🖥️",
    title: "Ordenadores",
    description: "Sobremesa y todo en uno para oficina, teletrabajo, gaming y uso doméstico.",
    priceRange: "€400 – €2.000",
    links: ["Para trabajo", "Gaming de sobremesa", "Todo en uno"],
  },
  {
    icon: "🎧",
    title: "Accesorios",
    description: "Auriculares, teclados, ratones, periféricos y complementos para mejorar tu setup.",
    priceRange: "€15 – €500",
    links: ["Auriculares", "Teclado y ratón", "Periféricos gaming"],
  },
  {
    icon: "⚡",
    title: "Movilidad eléctrica",
    description: "Patinetes, bicicletas y scooters eléctricos para ciudad, trayectos diarios y ocio.",
    priceRange: "€300 – €2.500",
    links: ["Patinete eléctrico", "Bicicleta eléctrica", "Scooter eléctrico"],
  },
];

const features = [
  {
    icon: "⚡",
    title: "Velocidad Extrema",
    text: "Resultados instantáneos para que no pierdas ni un segundo.",
  },
  {
    icon: "🛍️",
    title: "Catálogo Inteligente",
    text: "Selección curada de portátiles, móviles, tablets, ordenadores y accesorios.",
  },
  {
    icon: "🤖",
    title: "Asistente IA Dedicado",
    text: "Respuestas personalizadas basadas en tu contexto, necesidades y dudas finales.",
    highlight: true,
  },
];

const quickQuestions = [
  {
    icon: "💻",
    question: "¿Qué portátil comprar para estudiar o trabajar?",
    answer:
      "Depende de autonomía, peso, sistema operativo y tipo de tareas. El asistente descarta modelos sobredimensionados y te enseña los que encajan con tu ritmo real.",
  },
  {
    icon: "📱",
    question: "¿Qué móvil comprar si buscas buena cámara y batería?",
    answer:
      "No siempre hace falta subir a la gama más cara. EasyChoose cruza cámara, autonomía, tamaño y precio para encontrar el punto de equilibrio.",
  },
  {
    icon: "📟",
    question: "¿Qué tablet elegir para apuntes, lectura o diseño?",
    answer:
      "La mejor tablet cambia si priorizas stylus, ecosistema, brillo de pantalla, apps o portabilidad. El asistente te orienta según ese contexto.",
  },
  {
    icon: "⚡",
    question: "¿Qué accesorio o patinete merece realmente la pena?",
    answer:
      "La IA filtra opciones irrelevantes y se centra en compatibilidad, ergonomía, autonomía, seguridad y valor por precio.",
  },
];

const comparisonRows = [
  {
    factor: "Tiempo invertido",
    manual: "Horas comparando fichas técnicas, reviews y tiendas.",
    easychoose: "Un flujo guiado de pocos pasos con recomendación final clara.",
  },
  {
    factor: "Comprensión técnica",
    manual: "Tienes que interpretar specs y marketing de cada marca.",
    easychoose: "La IA traduce datos técnicos a impacto real en tu día a día.",
  },
  {
    factor: "Ajuste al presupuesto",
    manual: "Es fácil pagar de más por prestaciones que no vas a usar.",
    easychoose: "Prioriza valor, uso real y límites de precio desde el principio.",
  },
  {
    factor: "Dudas finales",
    manual: "La última incertidumbre suele obligarte a seguir buscando.",
    easychoose: "Puedes preguntar a la IA por batería, peso, cámara o compatibilidad antes de decidir.",
  },
  {
    factor: "Claridad de decisión",
    manual: "Muchísima información, poca conclusión accionable.",
    easychoose: "Una recomendación argumentada y fácil de entender.",
  },
];

const methodology = [
  {
    icon: "🎯",
    title: "Uso real antes que ficha técnica",
    description:
      "El asistente parte de lo que vas a hacer con el producto, no de una lista de especificaciones aisladas.",
  },
  {
    icon: "💰",
    title: "Valor por precio",
    description:
      "Compara opciones dentro de tu rango para evitar pagar de más o quedarte corto donde sí importa.",
  },
  {
    icon: "🔍",
    title: "Resultados que puedes interrogar",
    description:
      "Cada recomendación se puede revisar con el chat IA para convertir la duda final en una decisión informada.",
  },
  {
    icon: "🤖",
    title: "Transparencia comercial",
    description:
      "EasyChoose puede recibir comisiones de afiliación, pero la recomendación se formula según adecuación al uso, no por patrocinio de marca.",
  },
];

const faqs = [
  {
    question: "¿Qué es EasyChoose y cómo funciona?",
    answer:
      "EasyChoose es un asistente gratuito con IA para elegir tecnología. Te hace unas pocas preguntas sobre categoría, uso, presupuesto y preferencias, y te devuelve recomendaciones claras para que compres con más seguridad y menos ruido.",
  },
  {
    question: "¿Sirve aunque no entienda de procesadores, RAM o pantallas?",
    answer:
      "Sí. Está pensado precisamente para personas que quieren acertar sin tener que dominar especificaciones técnicas. El sistema traduce esos datos a lenguaje práctico y a impacto real en el uso diario.",
  },
  {
    question: "¿Qué productos puedo comparar con EasyChoose?",
    answer:
      "Actualmente cubre portátiles, smartphones, tablets, ordenadores de sobremesa, accesorios y categorías de movilidad eléctrica como patinetes, bicicletas y scooters.",
  },
  {
    question: "¿Las recomendaciones son gratuitas e imparciales?",
    answer:
      "Sí. El asistente es gratuito y no exige registro. EasyChoose puede monetizar a través de enlaces de afiliado, pero la selección se orienta a encaje con tus necesidades, no a promocionar una marca concreta.",
  },
  {
    question: "¿Puedo preguntar dudas concretas antes de comprar?",
    answer:
      "Sí. El chat IA permite bajar al detalle y preguntar, por ejemplo, si un portátil aguanta una jornada de universidad, si un móvil prioriza batería frente a cámara o si un accesorio es compatible con tu equipo.",
  },
  {
    question: "¿Para quién es útil: expertos o no expertos?",
    answer:
      "Para ambos perfiles. Quien no domina la tecnología gana claridad; quien ya la domina ahorra tiempo filtrando opciones y acelerando la decisión final.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Cómo elegir tecnología con EasyChoose",
  description:
    "Proceso guiado para elegir portátil, móvil, tablet, ordenador, accesorio o movilidad eléctrica con ayuda de IA.",
  totalTime: "PT2M",
  estimatedCost: {
    "@type": "MonetaryAmount",
    currency: "EUR",
    value: "0",
  },
  step: steps.map((step, index) => ({
    "@type": "HowToStep",
    position: index + 1,
    name: step.title,
    text: step.description,
  })),
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Categorías que cubre EasyChoose",
  itemListElement: categories.map((category, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: category.title,
    description: category.description,
    url: appUrl,
  })),
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Asistente IA para elegir tecnología",
  serviceType: "Recomendación personalizada de productos tecnológicos",
  url: canonical,
  provider: {
    "@type": "Organization",
    name: "EasyChoose",
    url: canonical,
  },
  areaServed: {
    "@type": "Country",
    name: "España",
  },
  audience: {
    "@type": "Audience",
    audienceType: "Consumidores que quieren elegir tecnología con seguridad",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "EUR",
  },
};

const pageSchemas = [faqSchema, howToSchema, itemListSchema, serviceSchema];
---

<Layout
  title="Qué portátil, móvil o tablet comprar | EasyChoose te ayuda a decidir con IA"
  description="EasyChoose es un asistente gratuito con IA para elegir portátil, móvil, tablet, ordenador, accesorio o movilidad eléctrica según uso real y presupuesto. Menos comparación ciega, más decisión clara."
  canonical={canonical}
  keywords={keywords}
>
  {pageSchemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <Section className="hero-section" variant="glass">
    <div class="hero-grid">
      <div class="hero-copy animate-fade-in">
        <span class="badge">Asistente IA gratuito</span>
        <h1>
          Qué portátil, móvil o tablet comprar <span class="highlight">sin perder horas comparando</span>
        </h1>
        <p class="hero-answer">
          EasyChoose es un asistente gratuito con IA que te ayuda a elegir tecnología según tu uso real, tu presupuesto y tus preferencias. En lugar de obligarte a interpretar fichas técnicas, resume el mercado en una recomendación clara y accionable.
        </p>
        <div class="hero-actions">
          <a href={appUrl} class="btn btn-primary btn-large">Empieza el Asistente Gratis</a>
          <a href="#how-it-works" class="btn-text">Ver cómo funciona</a>
        </div>
        <ul class="hero-pills" aria-label="Beneficios clave">
          <li>Gratis y sin registro</li>
          <li>Lenguaje claro para no expertos</li>
          <li>Comparación útil para decidir mejor</li>
        </ul>
      </div>

      <div class="hero-visual">
        <div class="hero-illustration-wrap" aria-label="Ilustración del asistente EasyChoose">
          <div class="hero-floating hero-floating-top hero-floating-outside">
            <span class="emoji-inline" aria-hidden="true">💬</span>
            <span>Te guiamos paso a paso</span>
          </div>
          <img
            src="/hero-illustration.png"
            alt="Ilustración del asistente EasyChoose recomendando tecnología según uso y presupuesto"
            class="hero-image"
            width="1000"
            height="1000"
          />
        </div>
      </div>
    </div>
  </Section>

  <Section id="features" className="features-section" variant="light">
    <div class="section-header">
      <span class="badge">Nuestra tecnología</span>
      <h2>Diseñado para la eficiencia</h2>
    </div>
    <div class="feature-grid">
      {features.map((feature) => (
        <article class={`feature-card ${feature.highlight ? "feature-card-highlight" : ""}`}>
          <div class="emoji-feature" aria-hidden="true">{feature.icon}</div>
          <h3>{feature.title}</h3>
          <p>{feature.text}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section id="answer-first" variant="light">
    <div class="section-header">
      <span class="badge">Respuesta rápida</span>
      <h2>¿Qué hace EasyChoose y para quién sirve?</h2>
      <p class="answer-first">
        EasyChoose sirve para personas que quieren comprar tecnología sin quedarse atrapadas entre especificaciones, comparativas interminables y miedo a equivocarse. Es útil tanto si no sabes de hardware como si sí sabes pero quieres llegar antes a una buena decisión.
      </p>
    </div>
    <div class="use-cases-grid">
      {useCases.map((useCase) => (
        <article class="info-card friendly-card friendly-centered">
          <div class="emoji-card" aria-hidden="true">{useCase.icon}</div>
          <h3>{useCase.title}</h3>
          <p>{useCase.description}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section id="problem" variant="glass">
    <div class="section-header">
      <span class="badge">El problema</span>
      <h2>¿Por qué comprar tecnología abruma tanto?</h2>
      <p>
        Porque la mayoría de comparativas te enseñan datos, pero no te ayudan a decidir. EasyChoose parte de la pregunta correcta: qué necesitas tú, en qué contexto y cuánto quieres gastar.
      </p>
    </div>
    <div class="problem-grid">
      {problems.map((problem) => (
        <article class="problem-item plain-problem">
          <div class="problem-icon plain-emoji" aria-hidden="true">{problem.icon}</div>
          <h3>{problem.title}</h3>
          <p>{problem.description}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section id="how-it-works" variant="light">
    <div class="section-header">
      <span class="badge">Proceso</span>
      <h2>¿Cómo funciona el asistente para elegir tecnología?</h2>
      <p>
        La experiencia está diseñada para ser rápida, guiada y accionable. Respondes unas pocas preguntas y obtienes una recomendación que puedes revisar con IA antes de comprar.
      </p>
    </div>
    <div class="steps-grid">
      {steps.map((step, index) => (
        <article class="step-card">
          <div class="step-number">{index + 1}</div>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section id="categories" variant="glass">
    <div class="section-header">
      <span class="badge">Categorías</span>
      <h2>¿Qué tipo de producto puedes elegir con EasyChoose?</h2>
      <p>
        La plataforma cubre las búsquedas más habituales de compra tecnológica y convierte cada categoría en una conversación guiada, no en un catálogo caótico.
      </p>
    </div>
    <div class="categories-grid">
      {categories.map((category) => (
        <article class="category-card">
          <div class="category-icon category-emoji" aria-hidden="true">{category.icon}</div>
          <h3>{category.title}</h3>
          <p>{category.description}</p>
          <div class="price-range">{category.priceRange}</div>
          <ul class="category-links">
            {category.links.map((link) => (
              <li><a href={appUrl} class="category-link">{link}</a></li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </Section>

  <Section id="questions" variant="light">
    <div class="section-header">
      <span class="badge">Intenciones de búsqueda</span>
      <h2>¿Qué preguntas resuelve mejor esta landing?</h2>
      <p>
        La página está pensada para responder consultas reales de compra en lenguaje natural y para conducirlas hacia una recomendación más precisa dentro del asistente.
      </p>
    </div>
    <div class="qa-grid">
      {quickQuestions.map((item) => (
        <article class="qa-card friendly-card improved-question-card">
          <div class="question-top">
            <div class="emoji-card emoji-card-small question-emoji" aria-hidden="true">{item.icon}</div>
            <span class="question-tag">Búsqueda frecuente</span>
          </div>
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
          <a href={appUrl}>Resolverlo en EasyChoose</a>
        </article>
      ))}
    </div>
  </Section>

  <Section id="comparison" variant="glass">
    <div class="section-header">
      <span class="badge">Comparativa</span>
      <h2>¿Qué cambia frente a buscar por tu cuenta?</h2>
      <p>
        Los motores generativos y los usuarios valoran las comparativas claras. Aquí la diferencia no es solo velocidad: es reducir ruido para llegar a una decisión defendible.
      </p>
    </div>
    <div class="table-wrap">
      <table class="comparison-table">
        <thead>
          <tr>
            <th scope="col">Factor</th>
            <th scope="col">Búsqueda manual</th>
            <th scope="col">EasyChoose</th>
          </tr>
        </thead>
        <tbody>
          {comparisonRows.map((row) => (
            <tr>
              <th scope="row">{row.factor}</th>
              <td>{row.manual}</td>
              <td>{row.easychoose}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Section>

  <Section id="methodology" variant="light">
    <div class="section-header">
      <span class="badge">Nuestra metodología</span>
      <h2>Por qué nuestras recomendaciones son diferentes</h2>
      <p class="answer-first">
        La recomendación se construye alrededor de uso, presupuesto, prioridades y dudas finales. El objetivo no es enseñarte todo el mercado, sino recortar el mercado hasta que la opción correcta para ti resulte evidente.
      </p>
    </div>
    <div class="methodology-list">
      {methodology.map((item) => (
        <article class="method-item">
          <div class="method-emoji" aria-hidden="true">{item.icon}</div>
          <div class="method-copy">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        </article>
      ))}
    </div>
    <div class="trust-note">
      <h3>Transparencia y confianza</h3>
      <p>
        Si compras a través de algunos enlaces, EasyChoose puede recibir una comisión sin coste adicional para ti. Puedes revisar la información legal en
        <a href="/aviso-legal/"> aviso legal</a> o escribir a
        <a href="/contacto/"> contacto</a> si necesitas aclaraciones.
      </p>
    </div>
  </Section>

  <Section id="faq" variant="glass">
    <div class="section-header">
      <span class="badge">FAQ</span>
      <h2>Preguntas frecuentes antes de empezar</h2>
      <p>
        Estas respuestas están redactadas para ser claras tanto para personas como para motores de respuesta. Si quieres tu caso concreto, el siguiente paso es probar el asistente.
      </p>
    </div>
    <div class="faq-list">
      {faqs.map((faq, index) => (
        <details class="faq-item" open={index === 0}>
          <summary>{faq.question}</summary>
          <p>{faq.answer}</p>
        </details>
      ))}
    </div>
  </Section>

  <Section variant="dark" className="cta-final">
    <div class="cta-content">
      <span class="badge badge-inverse">CTA principal</span>
      <h2>Empieza por una pregunta simple y termina con una compra mucho más clara</h2>
      <p>
        Si quieres elegir portátil, móvil, tablet, accesorio o movilidad eléctrica sin ruido técnico innecesario, el asistente está listo para guiarte.
      </p>
      <a href={appUrl} class="btn btn-secondary btn-large">Empieza el Asistente</a>
      <ul class="trust-pills">
        <li>Gratis y sin registro</li>
        <li>Orientado a uso real</li>
        <li>Con chat IA para la última duda</li>
      </ul>
    </div>
  </Section>
</Layout>

<style>
  .section-header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 3.5rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1rem;
    border-radius: 999px;
    background: rgba(108, 99, 255, 0.12);
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .badge-inverse {
    background: rgba(255, 255, 255, 0.14);
    color: white;
  }

  .section-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
  }

  .section-header p {
    color: var(--color-text-muted);
    font-size: 1.08rem;
  }

  .answer-first {
    font-size: 1.15rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    gap: 4rem;
    align-items: center;
    min-height: 82vh;
  }

  .hero-copy h1 {
    font-size: clamp(2.5rem, 5vw, 4.6rem);
