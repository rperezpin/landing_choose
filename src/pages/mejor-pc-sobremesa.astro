---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";

const canonical = "https://easychoose.es/mejor-pc-sobremesa/";
const appUrl = "https://app.easychoose.es/";
const siteUrl = "https://easychoose.es";
const today = new Date().toLocaleDateString("es-ES", { day: "numeric", month: "long", year: "numeric" });
const todayIso = new Date().toISOString().split("T")[0];

const criteria = [
  {
    icon: "⚡",
    title: "Equilibrio entre CPU y GPU según tu uso",
    description: "Un PC de sobremesa rinde según el componente más débil. Para gaming la GPU manda; para edición o multitarea pesada, la CPU y la RAM importan más. Evita desequilibrios que dejen un componente sin aprovechar.",
  },
  {
    icon: "💾",
    title: "Al menos 16 GB de RAM y SSD como unidad principal",
    description: "16 GB es el mínimo cómodo en 2026 para uso general y gaming; 32 GB si editas vídeo o trabajas con varias máquinas virtuales. Un SSD (NVMe a ser posible) marca más la diferencia diaria que unos GHz extra de CPU.",
  },
  {
    icon: "🌬️",
    title: "Refrigeración adecuada a la carga sostenida",
    description: "A diferencia de un portátil, un sobremesa puede mantener el rendimiento máximo durante horas si la refrigeración está bien dimensionada. Una torre con buen flujo de aire evita que el sistema se ralentice en sesiones largas.",
  },
  {
    icon: "💶",
    title: "Presupuesto entre 600€ y 1.500€",
    description: "El rango donde se concentra la mejor relación calidad-precio para sobremesa en 2026. Por debajo de 600€ los compromisos en GPU o almacenamiento se notan; por encima de 1.500€ entras en terreno de rendimientos decrecientes salvo para gaming o creación de contenido muy exigente.",
  },
  {
    icon: "🔌",
    title: "Fuente de alimentación con margen real",
    description: "Una fuente ajustada al límite envejece peor y limita futuras ampliaciones. Deja un margen de al menos 20% sobre el consumo estimado de tus componentes, especialmente si planeas añadir una GPU más potente más adelante.",
  },
  {
    icon: "🧩",
    title: "Posibilidad real de ampliación",
    description: "Comprueba que la caja y la placa base permiten añadir RAM, almacenamiento o cambiar la GPU en el futuro. Algunos PC prearmados muy compactos limitan mucho las opciones de ampliación posterior.",
  },
];

const profiles = [
  {
    icon: "🎮",
    type: "Gaming",
    description:
      "Para jugar con buena tasa de frames, la GPU es la prioridad clara, seguida de una CPU que no genere cuello de botella. La RAM y el almacenamiento rápido también influyen en tiempos de carga.",
    priority: "GPU y refrigeración",
    ram: "16–32 GB",
    budget: "800€ – 1.800€",
    tip: "Define primero a qué resolución y framerate quieres jugar: eso determina qué GPU necesitas y evita pagar de más por una CPU sobredimensionada para tu GPU real.",
  },
  {
    icon: "💼",
    type: "Oficina y uso doméstico",
    description:
      "Para navegación, ofimática, streaming y tareas domésticas no necesitas gama alta. La fiabilidad y un SSD rápido se notan mucho más que el rendimiento bruto en este perfil.",
    priority: "SSD y fiabilidad",
    ram: "8–16 GB",
    budget: "500€ – 800€",
    tip: "No pagues por una GPU dedicada potente si no vas a jugar ni editar vídeo: la gráfica integrada de la mayoría de procesadores actuales es suficiente.",
  },
  {
    icon: "🎬",
    type: "Edición y creación de contenido",
    description:
      "Edición de vídeo, renderizado 3D o producción musical exigen RAM abundante, almacenamiento rápido y, en la mayoría de casos, una GPU con buena aceleración para exportación.",
    priority: "RAM y GPU para exportación",
    ram: "32 GB",
    budget: "1.200€ – 2.000€",
    tip: "Verifica qué motor de aceleración usa tu software de edición (CUDA, OpenCL u otro) antes de elegir GPU: no todas las tarjetas rinden igual con cada programa.",
  },
  {
    icon: "🖥️",
    type: "Multitarea y trabajo técnico",
    description:
      "Si trabajas con varias máquinas virtuales, bases de datos locales o entornos de desarrollo pesados, la RAM y un procesador con varios núcleos marcan más diferencia que la GPU.",
    priority: "RAM y núcleos de CPU",
    ram: "32–64 GB",
    budget: "1.000€ – 1.700€",
    tip: "Cuenta cuántas máquinas virtuales o contenedores ejecutas a la vez habitualmente: cada una consume RAM dedicada que se suma rápido.",
  },
];

const faqs = [
  {
    question: "¿Cuál es el mejor PC de sobremesa por presupuesto en 2026?",
    answer:
      "El mejor PC de sobremesa por presupuesto en 2026 cuesta entre 600€ y 1.500€, con al menos 16 GB de RAM, SSD como unidad principal y un equilibrio entre CPU y GPU acorde a tu uso. El componente prioritario cambia según seas gamer, oficina, creación de contenido o trabajo técnico. EasyChoose filtra el mercado según tu uso real en menos de 2 minutos.",
  },
  {
    question: "¿Qué PC de sobremesa comprar para gaming sin gastar de más?",
    answer:
      "Para gaming sin sobrepagar, define primero la resolución y framerate objetivo: eso determina la GPU necesaria. Con 800€-1.200€ se consiguen equipos capaces de mover la mayoría de juegos actuales en 1080p o 1440p con buena tasa de frames.",
  },
  {
    question: "¿Cuánta RAM necesito para un PC de sobremesa en 2026?",
    answer:
      "16 GB es el mínimo cómodo para uso general y gaming en 2026. Si editas vídeo, usas máquinas virtuales o trabajas con varias herramientas pesadas a la vez, sube a 32 GB para evitar cuellos de botella.",
  },
  {
    question: "¿Merece la pena comprar un PC prearmado o montarlo a medida?",
    answer:
      "Un PC prearmado ahorra tiempo y suele incluir garantía completa del conjunto, ideal si no quieres complicarte. Montarlo a medida da más control sobre cada componente y a veces mejor relación calidad-precio, pero exige más conocimiento técnico y tiempo.",
  },
  {
    question: "¿Qué componente prioritario para edición de vídeo en sobremesa?",
    answer:
      "Para edición de vídeo prioriza RAM abundante (32 GB), almacenamiento rápido (SSD NVMe) y una GPU con buena aceleración para el motor de tu software de edición. El procesador importa, pero suele ser menos determinante que estos tres factores.",
  },
  {
    question: "¿Cuándo merece la pena gastar más de 1.500 euros en un sobremesa?",
    answer:
      "Por encima de 1.500€ tiene sentido si haces gaming en resoluciones altas con máxima calidad, edición de vídeo profesional o renderizado 3D intensivo. Para uso general, oficina o gaming moderado, esa inversión extra rara vez se traduce en una mejora notable del día a día.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": `${canonical}#article`,
  headline: "Mejor PC de sobremesa por presupuesto en 2026",
  description:
    "Guía para elegir el mejor PC de sobremesa en 2026: criterios reales, rangos de presupuesto y recomendaciones por perfil de uso con IA.",
  url: canonical,
  datePublished: "2026-06-20",
  dateModified: todayIso,
  inLanguage: "es-ES",
  author: {
    "@type": "Person",
    name: "Rubén Pérez",
    url: `${siteUrl}/contacto/`,
    sameAs: ["https://www.rpidev.com/", "https://www.linkedin.com/in/ruben-perez-rpidev/"],
  },
  publisher: {
    "@type": "Organization",
    name: "EasyChoose",
    url: `${siteUrl}/`,
    logo: {
      "@type": "ImageObject",
      url: `${siteUrl}/choose-removebg-preview.png`,
    },
  },
  image: {
    "@type": "ImageObject",
    url: `${siteUrl}/hero-illustration.png`,
    width: 1000,
    height: 1000,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonical,
  },
  about: [
    { "@type": "Thing", name: "PC de sobremesa" },
    { "@type": "Thing", name: "ordenador de sobremesa por presupuesto" },
    { "@type": "Thing", name: "PC gaming sobremesa" },
  ],
  keywords: [
    "mejor pc sobremesa 2026",
    "ordenador de sobremesa por presupuesto",
    "qué pc de sobremesa comprar",
    "pc gaming sobremesa barato",
    "pc para edición de vídeo",
  ],
};
---

<Layout
  title="Mejor PC de sobremesa por presupuesto 2026 | EasyChoose"
  description="Guía 2026 para elegir el mejor PC de sobremesa: criterios reales, rangos de presupuesto y recomendaciones con IA según gaming, oficina o creación de contenido."
  canonical={canonical}
  keywords={["mejor pc sobremesa", "ordenador de sobremesa por presupuesto", "que pc de sobremesa comprar", "pc gaming sobremesa barato", "pc para edicion de video"]}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />

  <!-- BreadcrumbList -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://easychoose.es/" },
      { "@type": "ListItem", "position": 2, "name": "Mejor PC de sobremesa", "item": "https://easychoose.es/mejor-pc-sobremesa/" }
    ]
  }
  </script>

  <Section variant="glass" className="cluster-hero">
    <div class="cluster-hero-content">
      <div class="hero-meta">
        <span class="badge">Guía de compra</span>
        <span class="last-updated">Actualizado: {today}</span>
      </div>
      <h1>Mejor PC de sobremesa por presupuesto en 2026</h1>
      <p class="lead">
        El mejor PC de sobremesa por presupuesto en 2026 cuesta entre 600€ y 1.500€, con al menos 16 GB de RAM, SSD como unidad principal y un equilibrio entre CPU y GPU según tu uso. Esta guía explica los criterios que realmente importan y te lleva al asistente IA para una recomendación concreta en menos de 2 minutos.
      </p>
      <a href={appUrl} class="btn btn-primary btn-large">Encontrar mi sobremesa ideal</a>
    </div>
  </Section>

  <Section variant="light" id="criterios">
    <div class="section-header">
      <span class="badge">Criterios</span>
      <h2>Qué buscar en un PC de sobremesa</h2>
      <p>
        Un sobremesa por presupuesto rinde según el equilibrio entre sus componentes, no según una sola especificación llamativa. EasyChoose pondera estos seis factores para identificar las mejores opciones.
      </p>
    </div>
    <div class="criteria-grid">
      {criteria.map((item) => (
        <article class="criteria-card">
          <div class="criteria-icon" aria-hidden="true">{item.icon}</div>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section variant="light" id="presupuesto">
    <div class="section-header">
      <span class="badge">Por presupuesto</span>
      <h2>¿Cuánto gastar en un PC de sobremesa?</h2>
      <p>
        El rango de precio define qué equilibrio de componentes puedes esperar. Estas son las franjas más habituales para sobremesa en 2026.
      </p>
    </div>
    <div class="budget-grid">
      <article class="budget-card">
        <div class="budget-range">500€ – 800€</div>
        <h3>Para oficina y uso doméstico</h3>
        <p>SSD rápido, 8-16 GB de RAM y gráfica integrada suficiente para navegación, ofimática y streaming. No pensado para gaming exigente ni edición pesada.</p>
        <a href={appUrl} class="budget-link">Ver opciones en este rango →</a>
      </article>
      <article class="budget-card budget-card-highlight">
        <div class="budget-badge-top">Rango recomendado</div>
        <div class="budget-range">800€ – 1.500€</div>
        <h3>La opción más equilibrada</h3>
        <p>Aquí encuentras 16-32 GB de RAM, GPU dedicada de gama media y suficiente potencia para gaming en 1080p/1440p o tareas de creación de contenido moderadas.</p>
        <a href={appUrl} class="budget-link">Ver opciones en este rango →</a>
      </article>
      <article class="budget-card">
        <div class="budget-range">Más de 1.500€</div>
        <h3>Para perfiles muy exigentes</h3>
        <p>GPU de gama alta, 32 GB de RAM o más y procesador potente. Recomendable solo para gaming en resoluciones altas, edición de vídeo profesional o renderizado 3D.</p>
        <a href={appUrl} class="budget-link">Ver opciones en este rango →</a>
      </article>
    </div>
  </Section>

  <Section variant="glass" id="por-perfil">
    <div class="section-header">
      <span class="badge">Por tipo de uso</span>
      <h2>¿Qué sobremesa necesitas según tu uso principal?</h2>
      <p>
        El sobremesa ideal cambia mucho según el uso: gaming, oficina, creación de contenido o trabajo técnico priorizan componentes distintos. Aquí están los criterios clave para cada perfil.
      </p>
    </div>
    <div class="career-grid">
      {profiles.map((profile) => (
        <article class="career-card">
          <div class="career-header">
            <span class="career-icon" aria-hidden="true">{profile.icon}</span>
            <h3>{profile.type}</h3>
          </div>
          <p class="career-desc">{profile.description}</p>
          <dl class="career-specs">
            <div class="spec-row">
              <dt>Prioridad principal</dt>
              <dd>{profile.priority}</dd>
            </div>
            <div class="spec-row">
              <dt>RAM recomendada</dt>
              <dd>{profile.ram}</dd>
            </div>
            <div class="spec-row">
              <dt>Presupuesto orientativo</dt>
              <dd>{profile.budget}</dd>
            </div>
          </dl>
          <p class="career-tip">💡 {profile.tip}</p>
          <a href={appUrl} class="career-cta">Ver opciones para mi perfil →</a>
        </article>
      ))}
    </div>
  </Section>

  <Section variant="glass" id="faq">
    <div class="section-header">
      <span class="badge">FAQ</span>
      <h2>Preguntas frecuentes sobre PC de sobremesa</h2>
    </div>
    <div class="faq-list">
      {faqs.map((faq, index) => (
        <details class="faq-item" open={index === 0}>
          <summary>{faq.question}</summary>
          <p>{faq.answer}</p>
        </details>
      ))}
    </div>
  </Section>

  <Section variant="dark" className="cta-final">
    <div class="cta-content">
      <span class="badge badge-inverse">Recomendación personalizada</span>
      <h2>Encuentra tu PC de sobremesa ideal en 2 minutos</h2>
      <p>
        Indica tu uso principal, el sistema operativo que prefieres y tu presupuesto. EasyChoose filtra el mercado y te devuelve las opciones que mejor encajan con tu situación concreta.
      </p>
      <a href={appUrl} class="btn btn-secondary btn-large">Empezar el Asistente Gratis</a>
      <ul class="trust-pills">
        <li>Gratis y sin registro</li>
        <li>Resultado en menos de 2 minutos</li>
        <li>Chat IA para la última duda</li>
      </ul>
    </div>
  </Section>
</Layout>

<style>
  .cluster-hero-content {
    max-width: 760px;
    padding: 5rem 0 4rem;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1rem;
    border-radius: 999px;
    background: rgba(108, 99, 255, 0.12);
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .badge-inverse {
    background: rgba(255, 255, 255, 0.14);
    color: white;
    margin-bottom: 1rem;
  }

  .last-updated {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  h1 {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    line-height: 1.1;
    margin-bottom: 1.25rem;
    color: var(--color-dark);
  }

  .lead {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 66ch;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .btn-large {
    padding: 1rem 2.35rem;
    font-size: 1.05rem;
  }

  .section-header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 3rem;
  }

  .section-header h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    margin: 0.5rem 0 1rem;
  }

  .section-header p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  .criteria-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .criteria-card {
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(46, 46, 46, 0.08);
    border-radius: 1.6rem;
    padding: 1.75rem;
    box-shadow: 0 18px 40px rgba(46, 46, 46, 0.06);
  }

  .criteria-icon {
    font-size: 2.2rem;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .criteria-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.6rem;
    color: var(--color-dark);
  }

  .criteria-card p {
    color: var(--color-text-muted);
    font-size: 0.96rem;
    line-height: 1.65;
  }

  .budget-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .budget-card {
    position: relative;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(46, 46, 46, 0.08);
    border-radius: 1.6rem;
    padding: 2rem 1.75rem;
    box-shadow: 0 18px 40px rgba(46, 46, 46, 0.06);
  }

  .budget-card-highlight {
    border-color: rgba(108, 99, 255, 0.7);
    padding-top: 3rem;
  }

  .budget-badge-top {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    background: var(--color-primary);
    color: white;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
  }

  .budget-range {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(108, 99, 255, 0.92), rgba(255, 211, 105, 0.92));
    color: white;
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 1rem;
  }

  .budget-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.6rem;
    color: var(--color-dark);
  }

  .budget-card p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .budget-link {
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.9rem;
  }

  .budget-link:hover {
    text-decoration: underline;
  }

  .faq-list {
    max-width: 860px;
    margin: 0 auto;
    display: grid;
    gap: 1rem;
  }

  .faq-item {
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(46, 46, 46, 0.08);
    border-radius: 1.4rem;
    padding: 1.2rem 1.3rem;
    box-shadow: 0 18px 36px rgba(46, 46, 46, 0.06);
  }

  .faq-item summary {
    cursor: pointer;
    font-weight: 700;
    list-style: none;
    padding-right: 2rem;
    position: relative;
    color: var(--color-dark);
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary::after {
    content: "+";
    position: absolute;
    right: 0;
    top: -0.1rem;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-primary);
  }

  .faq-item[open] summary::after { content: "−"; }

  .faq-item p {
    margin-top: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .cta-final :global(.container) { max-width: 860px; }

  .cta-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-content h2 {
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    margin-bottom: 1rem;
  }

  .cta-content p {
    max-width: 56ch;
    margin-bottom: 2rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.05rem;
  }

  .trust-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    list-style: none;
    margin-top: 1.5rem;
  }

  .trust-pills li {
    padding: 0.7rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.16);
    font-weight: 600;
  }

  .career-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .career-card {
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(46, 46, 46, 0.08);
    border-radius: 1.6rem;
    padding: 1.75rem;
    box-shadow: 0 18px 40px rgba(46, 46, 46, 0.06);
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .career-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .career-icon {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .career-header h3 {
    font-size: 1.1rem;
    color: var(--color-dark);
    margin: 0;
  }

  .career-desc {
    color: var(--color-text-muted);
    font-size: 0.94rem;
    line-height: 1.65;
    margin: 0;
  }

  .career-specs {
    display: grid;
    gap: 0.5rem;
    margin: 0;
  }

  .spec-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 0.88rem;
    border-bottom: 1px solid rgba(46, 46, 46, 0.06);
    padding-bottom: 0.4rem;
  }

  .spec-row dt {
